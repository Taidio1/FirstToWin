SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# Use the Supabase "Session pooler" connection string if your network does not support IPv6.
# Dashboard: Project -> Connect -> Connection string -> Session pooler
DB_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Enable Supabase Auth for /api/auth/login, /api/auth/register and Bearer token checks.
SUPABASE_AUTH_ENABLED=true
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-or-publishable-key>
