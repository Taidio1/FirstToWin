SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# Use the Supabase Postgres connection string here when you want app data stored in Supabase.
DB_URL=postgresql+psycopg://postgres:<password>@<host>:5432/postgres

# Enable Supabase Auth for /api/auth/login, /api/auth/register and Bearer token checks.
SUPABASE_AUTH_ENABLED=true
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-or-publishable-key>
