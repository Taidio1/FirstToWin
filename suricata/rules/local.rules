 # Port scan
  alert tcp any any -> $HOME_NET any (msg:"Port Scan Detected"; flags:S; threshold:type threshold, track by_src, count 15,
  seconds 60; sid:1000001; rev:1;)

  # Brute force SSH
  alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Detected"; flow:to_server; threshold:type threshold, track by_src,
  count 5, seconds 60; sid:1000002; rev:1;)

  # C2 Beacon
  alert tcp $HOME_NET any -> any any (msg:"Possible C2 Beacon"; flow:to_server,established; threshold:type both, track by_src,
  count 10, seconds 60; sid:1000003; rev:1;)